#!/usr/bin/env ruby
# frozen_string_literal: true

require "bundler/setup"
require "lxdb"
require "optparse"

options = {}

parser = OptionParser.new do |opts|
  opts.banner = "Usage: lxdb [options] [executable] [-- args...]"

  opts.on("-p", "--pid PID", Integer, "Attach to process") do |pid|
    options[:pid] = pid
  end

  opts.on("-c", "--command CMD", "Execute command on startup") do |cmd|
    options[:commands] ||= []
    options[:commands] << cmd
  end

  opts.on("-b", "--batch", "Exit after startup commands") do
    options[:batch] = true
  end

  opts.on("--launch", "Launch executable before startup commands") do
    options[:launch] = true
  end

  opts.on("--check-lldb-bindings", "Check whether LLDB Ruby bindings are available") do
    options[:check_lldb_bindings] = true
  end

  opts.on("--no-color", "Disable color output") do
    options[:no_color] = true
  end

  opts.on("-t", "--tui", "Start in TUI mode") do
    options[:tui] = true
  end

  opts.on("-v", "--version", "Show version") do
    puts "lxdb version #{Lxdb::VERSION}"
    exit
  end

  opts.on("-h", "--help", "Show this help") do
    puts opts
    exit
  end
end

# Parse arguments, stopping at '--'
args = ARGV.dup
program_args = []
if (idx = args.index("--"))
  program_args = args[(idx + 1)..] || []
  args = args[0...idx]
end

parser.parse!(args)
executable = args.first

# Create config
config = Lxdb::Config.new
config.color_enabled = !options[:no_color]

# LLDB binding preflight
if options[:check_lldb_bindings]
  begin
    session = Lxdb.start(nil, config: config)
    puts "LLDB Ruby bindings: available"
    exit 0
  rescue Lxdb::Error => e
    warn "LLDB Ruby bindings: unavailable: #{e.message}"
    exit 1
  ensure
    session&.terminate
  end
end

# Start session
begin
  session = Lxdb.start(executable, config: config)

  # Handle --pid
  if options[:pid]
    session.attach(options[:pid])
  elsif options[:launch]
    raise Lxdb::CommandError, "--launch requires an executable" unless executable

    session.launch(args: program_args)
  end

  # Execute startup commands through the lxdb command dispatcher.
  command_runner = Lxdb::UI::CLI::REPL.new(session)
  options[:commands]&.each do |cmd|
    puts "> #{cmd}"
    command_runner.execute(cmd)
  end

  exit if options[:batch]

  # Run interface
  if options[:tui]
    Lxdb::UI::TUI::Application.new(session).run
  else
    command_runner.run
  end
rescue Lxdb::Error => e
  warn "Error: #{e.message}"
  exit 1
rescue Interrupt
  puts "\nInterrupted"
  exit 130
ensure
  session&.terminate
end
